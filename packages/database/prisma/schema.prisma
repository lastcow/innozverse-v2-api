generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SYSTEM
}

enum OAuthProvider {
  LOCAL
  GOOGLE
  GITHUB
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationMethod {
  EDU_EMAIL
  MANUAL_UPLOAD
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String?        @map("password_hash")
  fname         String?        @map("fname")
  mname         String?        @map("mname")
  lname         String?        @map("lname")
  role          Role           @default(USER)
  status        UserStatus     @default(ACTIVE)
  oauthProvider OAuthProvider? @map("oauth_provider")
  oauthId       String?        @map("oauth_id")
  emailVerified Boolean        @default(false) @map("email_verified")
  stripeCustomerId String?   @unique @map("stripe_customer_id")
  deletedAt     DateTime?      @map("deleted_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  studentVerification   StudentVerification?
  verificationsApproved StudentVerification[] @relation("ApprovedBy")
  carts                 Cart[]
  orders                Order[]
  workshopRegistrations WorkshopRegistration[]
  studioBookings        StudioBooking[]
  subscription          UserSubscription?
  virtualMachines       VirtualMachine[]
  serviceSubscriptions  ServiceSubscription[]

  @@unique([oauthProvider, oauthId])
  @@map("users")
}

model StudentVerification {
  id                 String             @id @default(uuid())
  userId             String             @unique @map("user_id")
  status             VerificationStatus @default(PENDING)
  verificationMethod VerificationMethod @map("verification_method")
  eduEmail           String?            @map("edu_email")
  proofUrl           String?            @map("proof_url")
  adminNotes         String?            @map("admin_notes") @db.Text
  verifiedAt         DateTime?          @map("verified_at")
  verifiedById       String?            @map("verified_by_id")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifiedBy User? @relation("ApprovedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("student_verifications")
}

enum ProductType {
  SURFACE
  LAPTOP
  XBOX
  ACCESSORY
  STEM
}

model Product {
  id          String      @id @default(uuid())
  name        String
  description String      @db.Text
  type        ProductType
  upc         String      @default("")
  basePrice   Decimal     @map("base_price") @db.Decimal(10, 2)
  stock       Int         @default(0)
  soldCount   Int         @default(0) @map("sold_count")
  active      Boolean     @default(true)
  properties  Json        @default("{}")
  imageUrls                 Json     @default("[]") @map("image_urls")
  isRefurbished             Boolean  @default(false) @map("is_refurbished")
  isOpenBox                 Boolean  @default(false) @map("is_open_box")
  studentDiscountPercentage Decimal? @map("student_discount_percentage") @db.Decimal(5, 2)
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  cartItems  CartItem[]
  orderItems OrderItem[]
  workshops  WorkshopProduct[]

  @@map("products")
  @@index([type, active])
  @@index([active, createdAt])
}

model ProductPropertyTemplate {
  id          String      @id @default(uuid())
  productType ProductType @unique @map("product_type")
  schema      Json
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("product_property_templates")
}

model Cart {
  id        String    @id @default(uuid())
  userId    String?   @map("user_id")
  sessionId String?   @map("session_id")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId])
  @@index([sessionId])
  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String   @map("cart_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  addedAt   DateTime @default(now()) @map("added_at")

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("cart_items")
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id                    String      @id @default(uuid())
  userId                String      @map("user_id")
  status                OrderStatus @default(PENDING)
  subtotal              Decimal     @db.Decimal(10, 2)
  discountAmount        Decimal     @default(0) @map("discount_amount") @db.Decimal(10, 2)
  tax                   Decimal     @default(0) @db.Decimal(10, 2)
  total                 Decimal     @db.Decimal(10, 2)
  stripeSessionId       String?     @unique @map("stripe_session_id")
  stripePaymentIntentId String?     @map("stripe_payment_intent_id")
  placedAt              DateTime    @default(now()) @map("placed_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  user  User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  items OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String   @map("order_id")
  productId       String   @map("product_id")
  quantity        Int
  priceAtPurchase Decimal  @map("price_at_purchase") @db.Decimal(10, 2)
  productSnapshot Json     @map("product_snapshot")
  serialNumber    String?  @map("serial_number")
  createdAt       DateTime @default(now()) @map("created_at")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("order_items")
}

model EventDiscount {
  id          String    @id @default(uuid())
  name        String
  description String?   @db.Text
  percentage  Decimal   @db.Decimal(5, 2)
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([active, startDate, endDate])
  @@map("event_discounts")
}

model Workshop {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  imageUrls   Json     @default("[]") @map("image_urls")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  capacity    Int      @default(0)
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  registrations WorkshopRegistration[]
  products      WorkshopProduct[]

  @@index([isPublished, startDate])
  @@map("workshops")
}

model WorkshopRegistration {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  workshopId String   @map("workshop_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@unique([userId, workshopId])
  @@index([workshopId])
  @@map("workshop_registrations")
}

model WorkshopProduct {
  id         String @id @default(uuid())
  workshopId String @map("workshop_id")
  productId  String @map("product_id")
  quantity   Int    @default(1)

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([workshopId, productId])
  @@index([productId])
  @@map("workshop_products")
}

model StudioSlot {
  id          String   @id @default(uuid())
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  capacity    Int      @default(10)
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  bookings StudioBooking[]

  @@index([startTime, isAvailable])
  @@map("studio_slots")
}

model StudioBooking {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  slotId    String   @map("slot_id")
  status    String   @default("CONFIRMED")
  createdAt DateTime @default(now()) @map("created_at")

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  slot StudioSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@unique([userId, slotId])
  @@index([slotId])
  @@index([userId])
  @@map("studio_bookings")
}

model VirtualMachine {
  id        String    @id @default(cuid())
  vmid      Int       @unique
  name      String
  type      String?
  node      String    @default("pve")
  status    String    @default("stopped")
  memory    Int       @default(2048)
  cpuCores  Int       @default(2) @map("cpu_cores")
  ipAddress       String?   @map("ip_address")
  publicIpAddress String?   @map("public_ip_address")
  port            Int?
  gateway         String?
  username        String?
  password        String?
  userId          String?   @map("user_id")
  subscriptionId  String?   @map("subscription_id")
  storage         String?
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user         User?             @relation(fields: [userId], references: [id])
  subscription UserSubscription? @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([deletedAt])
  @@index([subscriptionId])
  @@map("virtual_machines")
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  active    Boolean  @default(true)
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([active, startDate, endDate])
  @@map("announcements")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  TRIALING
}

model Plan {
  id               String   @id @default(uuid())
  name             String   @unique
  level            Int      @unique
  monthlyPrice     Float    @map("monthly_price")
  annualTotalPrice Float    @map("annual_total_price")
  description      String   @db.Text
  highlights       Json     @default("[]")
  vmConfig         Json     @default("[]") @map("vm_config")
  active           Boolean  @default(true)
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  subscriptions UserSubscription[]

  @@index([active, sortOrder])
  @@map("plans")
}

model UserSubscription {
  id                   String             @id @default(uuid())
  userId               String             @unique @map("user_id")
  planId               String             @map("plan_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  stripeCustomerId     String?            @map("stripe_customer_id")
  status               SubscriptionStatus @default(ACTIVE)
  billingPeriod        String             @default("monthly") @map("billing_period")
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  canceledAt           DateTime?          @map("canceled_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id], onDelete: Restrict)

  virtualMachines VirtualMachine[]

  @@index([status])
  @@map("user_subscriptions")
}

model Storage {
  id         String   @id @default(uuid())
  name       String   @unique
  node       String   @default("pve")
  type       String?
  totalBytes BigInt   @default(0) @map("total_bytes")
  usedBytes  BigInt   @default(0) @map("used_bytes")
  availBytes BigInt   @default(0) @map("avail_bytes")
  active     Boolean  @default(true)
  vmable     Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([active, vmable])
  @@map("storages")
}

model VmTemplate {
  id        String   @id @default(cuid())
  vmid      Int      @unique
  osType    String   @map("os_type")
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([osType, active])
  @@map("vm_templates")
}

model IpPool {
  id          String         @id @default(cuid())
  name        String
  startIp     String         @map("start_ip")
  endIp       String         @map("end_ip")
  cidr        Int            @default(24)
  gateway     String
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  allocations IpAllocation[]

  @@map("ip_pools")
}

model IpAllocation {
  id        String   @id @default(cuid())
  ipAddress String   @unique @map("ip_address")
  poolId    String   @map("pool_id")
  vmid      Int
  createdAt DateTime @default(now()) @map("created_at")

  pool IpPool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@index([poolId])
  @@map("ip_allocations")
}

enum ServiceStatus {
  PENDING_SETUP
  IN_PROGRESS
  RUNNING
  CANCELED
  SUSPENDED
}

model ServiceSubscription {
  id                   String        @id @default(uuid())
  userId               String        @map("user_id")
  serviceName          String        @map("service_name")
  stripeSubscriptionId String?       @unique @map("stripe_subscription_id")
  stripeCustomerId     String?       @map("stripe_customer_id")
  status               ServiceStatus @default(PENDING_SETUP)
  billingPeriod        String        @default("monthly") @map("billing_period")
  monthlyPrice         Float         @map("monthly_price")
  currentPeriodStart   DateTime?     @map("current_period_start")
  currentPeriodEnd     DateTime?     @map("current_period_end")
  canceledAt           DateTime?     @map("canceled_at")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("service_subscriptions")
}
